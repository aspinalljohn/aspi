{% block scripts %}
<script>
    // Sticky bottom bar: show after scrolling past hero, hide near final CTA
    document.addEventListener('DOMContentLoaded', function() {
        var sticky = document.getElementById('cohort-sticky');
        var hero = document.querySelector('.cohort-hero');
        var finalCta = document.getElementById('cohort-final-cta');
        var heroVisible = true;
        var ctaVisible = false;

        function updateSticky() {
            if (!heroVisible && !ctaVisible) {
                sticky.classList.add('visible');
            } else {
                sticky.classList.remove('visible');
            }
        }

        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.target === hero) {
                    heroVisible = entry.isIntersecting;
                } else if (entry.target === finalCta) {
                    ctaVisible = entry.isIntersecting;
                }
                updateSticky();
            });
        }, { threshold: 0 });

        if (hero) observer.observe(hero);
        if (finalCta) observer.observe(finalCta);
    });
</script>
{% endblock %}
