for brand_name in brands:
    brand = client.search_brands(brand_name=brand_name, page_size=1)
    products = client.search_products(brand_name=brand_name, page_size=25)
    segment_data["brands"].append(brand)
    segment_data["products"].extend(products.get("data", products.get("records", [])))

# Pull ASIN data
for asin in asins:
