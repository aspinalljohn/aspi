---
title: "Blog | Aspi — Marketplace Creative Strategy Insights"
description: "Actionable insights on Amazon hero image optimization, marketplace CTR strategy, and creative that converts. From the team behind 14,000+ optimized listings."
layout: base.njk
permalink: /blog/
tags: []
eleventyExcludeFromCollections: true
---

{% block content %}
    <section class="section blog-listing-section">
        <div class="container">
            <div class="blog-listing-header">
                <h1 class="section-headline center">Marketplace Creative Strategy Blog</h1>
                <p class="blog-listing-subtitle">Insights on hero image optimization, CTR strategy, and visual decisions that drive marketplace revenue.</p>
            </div>

            <div class="blog-listing">
                {% for post in collections.posts %}
                <a href="{{ post.url }}" class="blog-card">
                    <div class="blog-card-content">
                        <div class="blog-card-meta">
                            <time datetime="{{ post.data.date | isoDate }}">{{ post.data.date | dateFormat }}</time>
                        </div>
                        <h2 class="blog-card-title">{{ post.data.title }}</h2>
                        <p class="blog-card-description">{{ post.data.description }}</p>
                        <span class="blog-card-link">Read more &rarr;</span>
                    </div>
                </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}
